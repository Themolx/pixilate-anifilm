# Copy to .env.local and fill in. Never commit .env.local.
# The anon key is public by design — RLS policies are the real defense.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL the bundle is served from. Keep the trailing slash.
# GitHub Pages at themolx.github.io/pixilate/ → /pixilate/
# Custom domain at root → /
VITE_PIXILATE_DEPLOY_BASE=/pixilate/

# Matches the cap enforced by the DB trigger (see 0004_triggers.sql).
# Client uses this only for the "frames left" UI hint.
VITE_FRAME_CAP=500
